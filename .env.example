# Lyfe N' Locs — environment variables. Copy to .env.local (git-ignored) and fill in.
# With NO booking keys set, the portal runs in DEMO MODE on mock data (fully demoable).

# Public site origin — canonical URLs, sitemap, robots, JSON-LD, link previews.
# Live Netlify site: https://lyfenlocs.netlify.app (also set in netlify.toml).
# When a custom domain is ready, change this AND netlify.toml to that domain.
NEXT_PUBLIC_SITE_URL=https://lyfenlocs.netlify.app

# Booking engine: "square" (default) or "stripe-standalone".
NEXT_PUBLIC_BOOKING_ENGINE=square

# --- Option 1: Square (default). Present both to leave demo mode. ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_APP_ID=

# --- Option 2: Stripe standalone (only if NEXT_PUBLIC_BOOKING_ENGINE=stripe-standalone) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- Notifications (confirmation + reminder hooks) — 【CONFIRM provider】 ---
# e.g. Twilio (SMS) / Postmark (email)
NOTIFICATIONS_PROVIDER=
